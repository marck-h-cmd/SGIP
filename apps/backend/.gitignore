# =========================
# Backend - .gitignore
# =========================

# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables
.env
.env.local

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Testing / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# Type checking
.mypy_cache/
.pyright/
.ruff_cache/

# Database
*.db
*.sqlite3

# Alembic (mantener versiones, ignorar artefactos locales)
alembic/*.pyc

# Jupyter
.ipynb_checkpoints/

# Modelos ML entrenados / artefactos pesados
*.pkl
*.joblib
model_registry/*.bin

# Editor
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
